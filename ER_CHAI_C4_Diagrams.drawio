          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ALB → API -->
        <mxCell id="ce7" value="Routes /api/*" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#707070;strokeWidth=2;fontColor=#707070;fontSize=10;" edge="1" source="c-alb" target="c-api" parent="1">
