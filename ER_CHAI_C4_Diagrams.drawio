          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- API → Bedrock -->
        <mxCell id="ce9" value="AI Chat, Vision,&lt;br&gt;Summaries" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#707070;strokeWidth=2;fontColor=#707070;fontSize=10;dashed=1;" edge="1" source="c-api" target="c-bedrock" parent="1">
          <mxGeometry relative="1" as="geometry"/>
