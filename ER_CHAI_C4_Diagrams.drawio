  <!-- ════════════════════════════════════════════════════════════ -->
  <!-- C4 Level 1: System Context Diagram                          -->
  <!-- ════════════════════════════════════════════════════════════ -->
  <diagram id="c4-context" name="C4 Level 1 - System Context">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="ctx-title" value="C4 Level 1 — System Context Diagram: ER-CHAI" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#003B5C;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="800" height="40" as="geometry"/>
        </mxCell>

        <!-- ═══ Person: Economist ═══ -->
        <mxCell id="economist" value="&lt;b&gt;Economist / Researcher&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Person]&lt;br&gt;&lt;br&gt;Creates, customizes, and exports&lt;br&gt;FRBSF-branded economic charts&lt;br&gt;using AI-assisted tools" style="shape=mxgraph.c4.person2;whiteSpace=wrap;html=1;align=center;metaEdit=1;points=[[0.5,0,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0]];fillColor=#08427B;fontColor=#ffffff;strokeColor=#073B6F;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="280" width="200" height="180" as="geometry"/>
        </mxCell>

        <!-- ═══ System: ER-CHAI ═══ -->
        <mxCell id="erchai" value="&lt;b&gt;ER-CHAI Platform&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Software System]&lt;br&gt;&lt;br&gt;AI-assisted chart generation and&lt;br&gt;analysis platform for economic&lt;br&gt;research. Ingests data, renders&lt;br&gt;interactive charts, provides AI&lt;br&gt;chat, generates summaries,&lt;br&gt;and exports to Python/R/PDF." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3C7FC0;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="530" y="240" width="280" height="260" as="geometry"/>
        </mxCell>

        <!-- ═══ External: FRED API ═══ -->
        <mxCell id="fred-ext" value="&lt;b&gt;FRED API&lt;/b&gt;&lt;br&gt;&lt;br&gt;[External System]&lt;br&gt;&lt;br&gt;Federal Reserve Economic Data.&lt;br&gt;Provides economic time series&lt;br&gt;datasets via REST API." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#8A8A8A;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="100" width="240" height="180" as="geometry"/>
        </mxCell>

        <!-- ═══ External: AWS Bedrock ═══ -->
        <mxCell id="bedrock-ext" value="&lt;b&gt;AWS Bedrock&lt;/b&gt;&lt;br&gt;(Claude Sonnet 4.5)&lt;br&gt;&lt;br&gt;[External System]&lt;br&gt;&lt;br&gt;Managed LLM service.&lt;br&gt;Provides AI chat, vision&lt;br&gt;analysis, and summary&lt;br&gt;generation capabilities." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#8A8A8A;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="370" width="240" height="200" as="geometry"/>
        </mxCell>

        <!-- ═══ External: Okta ═══ -->
        <mxCell id="okta-ext" value="&lt;b&gt;Okta IdP&lt;/b&gt;&lt;br&gt;&lt;br&gt;[External System]&lt;br&gt;&lt;br&gt;Identity provider for&lt;br&gt;SSO authentication&lt;br&gt;(SAML / OIDC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#8A8A8A;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="640" width="240" height="160" as="geometry"/>
        </mxCell>

        <!-- ═══ Connections ═══ -->
        <mxCell id="ctx-e1" value="Uses [HTTPS]&lt;br&gt;Creates charts, asks AI questions,&lt;br&gt;exports publications" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#707070;strokeWidth=2;fontColor=#707070;fontSize=10;entryX=0;entryY=0.5;" edge="1" source="economist" target="erchai" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ctx-e2" value="Downloads economic&lt;br&gt;datasets [REST/JSON]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#707070;strokeWidth=2;fontColor=#707070;fontSize=10;dashed=1;" edge="1" source="erchai" target="fred-ext" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ctx-e3" value="AI chat, vision analysis,&lt;br&gt;summary generation [REST/JSON]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#707070;strokeWidth=2;fontColor=#707070;fontSize=10;dashed=1;" edge="1" source="erchai" target="bedrock-ext" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ctx-e4" value="Authenticates users&lt;br&gt;[SAML/OIDC]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#707070;strokeWidth=2;fontColor=#707070;fontSize=10;dashed=1;" edge="1" source="erchai" target="okta-ext" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ════════════════════════════════════════════════════════════ -->
  <!-- C4 Level 2: Container Diagram                               -->
