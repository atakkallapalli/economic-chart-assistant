      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="cnt-title" value="C4 Level 2 — Container Diagram: ER-CHAI Platform" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#003B5C;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="900" height="40" as="geometry"/>
        </mxCell>

        <!-- ═══ Person ═══ -->
        <mxCell id="c-user" value="&lt;b&gt;Economist&lt;/b&gt;&lt;br&gt;[Person]" style="shape=mxgraph.c4.person2;whiteSpace=wrap;html=1;align=center;fillColor=#08427B;fontColor=#ffffff;strokeColor=#073B6F;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="350" width="140" height="130" as="geometry"/>
        </mxCell>

        <!-- ═══ System Boundary ═══ -->
        <mxCell id="sys-boundary" value="ER-CHAI Platform [Software System]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#438DD5;strokeWidth=2;dashed=1;fontSize=14;fontStyle=1;fontColor=#438DD5;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="250" y="60" width="960" height="870" as="geometry"/>
        </mxCell>

        <!-- ═══ Container: React SPA ═══ -->
        <mxCell id="c-spa" value="&lt;b&gt;React SPA&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Container: React 18, TypeScript,&lt;br&gt;Konva.js, Zustand]&lt;br&gt;&lt;br&gt;Interactive chart editor with&lt;br&gt;AI chat, drag-and-drop canvas,&lt;br&gt;controls panel, and export tools.&lt;br&gt;&lt;br&gt;Hosted on S3 + CloudFront" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3C7FC0;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="310" y="100" width="260" height="220" as="geometry"/>
        </mxCell>

        <!-- ═══ Container: FastAPI Backend ═══ -->
        <mxCell id="c-api" value="&lt;b&gt;FastAPI Backend&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Container: Python 3.11, FastAPI,&lt;br&gt;uvicorn, ECS Fargate]&lt;br&gt;&lt;br&gt;REST API handling data ingestion,&lt;br&gt;AI chat routing, summary generation,&lt;br&gt;export generation, and project CRUD.&lt;br&gt;15+ endpoints under /api/*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3C7FC0;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="310" y="420" width="260" height="230" as="geometry"/>
        </mxCell>

        <!-- ═══ Container: Aurora DB ═══ -->
        <mxCell id="c-db" value="&lt;b&gt;Aurora PostgreSQL&lt;/b&gt;&lt;br&gt;Serverless v2&lt;br&gt;&lt;br&gt;[Container: Database]&lt;br&gt;&lt;br&gt;Stores projects, chart state&lt;br&gt;(JSON), metadata, timestamps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3C7FC0;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="100" width="220" height="180" as="geometry"/>
        </mxCell>

        <!-- ═══ Container: S3 Storage ═══ -->
        <mxCell id="c-s3" value="&lt;b&gt;S3 Data Store&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Container: Object Storage]&lt;br&gt;&lt;br&gt;Datasets (CSV/Excel),&lt;br&gt;chart images, export&lt;br&gt;artifacts (zip, PDF)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3C7FC0;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="350" width="220" height="170" as="geometry"/>
        </mxCell>

        <!-- ═══ Container: Redis Cache ═══ -->
        <mxCell id="c-redis" value="&lt;b&gt;ElastiCache (Redis)&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Container: Cache]&lt;br&gt;&lt;br&gt;AI session history,&lt;br&gt;prompt caching,&lt;br&gt;rate limiting" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3C7FC0;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="590" width="220" height="160" as="geometry"/>
        </mxCell>

        <!-- ═══ Container: SQS Queue ═══ -->
        <mxCell id="c-sqs" value="&lt;b&gt;SQS Queue&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Container: Message Queue]&lt;br&gt;&lt;br&gt;Async processing for&lt;br&gt;image analysis and&lt;br&gt;PDF/export generation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3C7FC0;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="810" width="220" height="100" as="geometry"/>
        </mxCell>

        <!-- ═══ Container: ALB ═══ -->
        <mxCell id="c-alb" value="&lt;b&gt;ALB + WAF&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Container: Load Balancer]&lt;br&gt;&lt;br&gt;OIDC auth via Okta,&lt;br&gt;WAF rules, routing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3C7FC0;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="310" y="730" width="260" height="130" as="geometry"/>
        </mxCell>

        <!-- ═══ External Systems ═══ -->
        <mxCell id="c-okta" value="&lt;b&gt;Okta IdP&lt;/b&gt;&lt;br&gt;[External: SAML/OIDC]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#8A8A8A;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="100" width="180" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="c-bedrock" value="&lt;b&gt;AWS Bedrock&lt;/b&gt;&lt;br&gt;Claude Sonnet 4.5&lt;br&gt;[External: LLM + Vision]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#8A8A8A;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="250" width="180" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="c-fred" value="&lt;b&gt;FRED API&lt;/b&gt;&lt;br&gt;[External: REST API]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#8A8A8A;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="410" width="180" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="c-cw" value="&lt;b&gt;CloudWatch + X-Ray&lt;/b&gt;&lt;br&gt;[External: Observability]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#8A8A8A;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="550" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- ═══ Connections ═══ -->
        <!-- User → SPA -->
        <mxCell id="ce1" value="Uses [HTTPS]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#707070;strokeWidth=2;fontColor=#707070;fontSize=10;" edge="1" source="c-user" target="c-spa" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- SPA → API -->
        <mxCell id="ce2" value="REST API calls&lt;br&gt;[JSON/HTTPS]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#707070;strokeWidth=2;fontColor=#707070;fontSize=10;" edge="1" source="c-spa" target="c-api" parent="1">
          <mxGeometry relative="1" as="geometry"/>
