  <!-- ════════════════════════════════════════════════════════════ -->
  <!-- C4 Level 3: Component Diagram (Backend)                     -->
  <!-- ════════════════════════════════════════════════════════════ -->
  <diagram id="c4-component" name="C4 Level 3 - Component (Backend)">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="cmp-title" value="C4 Level 3 — Component Diagram: FastAPI Backend" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#003B5C;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="900" height="40" as="geometry"/>
        </mxCell>

        <!-- ═══ Container Boundary ═══ -->
        <mxCell id="api-boundary" value="FastAPI Backend [Container: Python 3.11, ECS Fargate]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#438DD5;strokeWidth=2;dashed=1;fontSize=14;fontStyle=1;fontColor=#438DD5;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="200" y="60" width="1200" height="980" as="geometry"/>
        </mxCell>

        <!-- ═══ Component: API Router ═══ -->
        <mxCell id="k-router" value="&lt;b&gt;API Router&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Component: FastAPI Router]&lt;br&gt;&lt;br&gt;15+ REST endpoints under /api/*.&lt;br&gt;Routes requests to services.&lt;br&gt;Health check, Bedrock status." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#78A8D8;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="250" y="100" width="240" height="160" as="geometry"/>
        </mxCell>

        <!-- ═══ Component: Middleware ═══ -->
        <mxCell id="k-mw" value="&lt;b&gt;Error Handling&lt;br&gt;Middleware&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Structured JSON errors,&lt;br&gt;12+ error types,&lt;br&gt;HTTP status mapping" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#78A8D8;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="250" y="320" width="240" height="150" as="geometry"/>
        </mxCell>

        <!-- ═══ Component: Config Loader ═══ -->
        <mxCell id="k-cfg" value="&lt;b&gt;Config Loader&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Component: config.py]&lt;br&gt;&lt;br&gt;Loads YAML config at startup.&lt;br&gt;Validates API keys and&lt;br&gt;AWS credentials." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#78A8D8;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="250" y="530" width="240" height="140" as="geometry"/>
        </mxCell>

        <!-- ═══ Component: Data Ingestion Service ═══ -->
        <mxCell id="k-ingest" value="&lt;b&gt;Data Ingestion Service&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Component: ingestion.py]&lt;br&gt;&lt;br&gt;Orchestrates FRED download,&lt;br&gt;CSV/Excel parsing, long-format&lt;br&gt;pivot, image analysis, and&lt;br&gt;default chart spec generation.&lt;br&gt;FRBSF branding defaults." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#78A8D8;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="580" y="100" width="240" height="200" as="geometry"/>
        </mxCell>

        <!-- ═══ Component: FRED Client ═══ -->
        <mxCell id="k-fred" value="&lt;b&gt;FRED Client&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Component: fred_client.py]&lt;br&gt;&lt;br&gt;Downloads FRED series.&lt;br&gt;URL parsing, retry logic&lt;br&gt;(3 attempts, exp backoff)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#78A8D8;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="580" y="360" width="240" height="150" as="geometry"/>
        </mxCell>

        <!-- ═══ Component: Image Analyzer ═══ -->
        <mxCell id="k-img" value="&lt;b&gt;Image Analyzer&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Component: image_analyzer.py]&lt;br&gt;&lt;br&gt;Dual pipeline: OpenCV (colors,&lt;br&gt;contours, text regions) +&lt;br&gt;Bedrock Vision (20-field&lt;br&gt;comprehensive analysis).&lt;br&gt;Merges into ChartSpecification." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#78A8D8;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="580" y="570" width="240" height="200" as="geometry"/>
        </mxCell>

        <!-- ═══ Component: AI Assistant ═══ -->
        <mxCell id="k-ai" value="&lt;b&gt;AI Assistant Handler&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Component: ai_assistant.py]&lt;br&gt;&lt;br&gt;3 intents: chart_modify,&lt;br&gt;data_qa, summary_update.&lt;br&gt;Per-session conversation&lt;br&gt;history. Bedrock invocation&lt;br&gt;with retry (2 attempts)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#78A8D8;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="100" width="240" height="200" as="geometry"/>
        </mxCell>

        <!-- ═══ Component: Summary Generator ═══ -->
        <mxCell id="k-sum" value="&lt;b&gt;Summary Generator&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Component: summary_generator.py]&lt;br&gt;&lt;br&gt;Generates executive summaries:&lt;br&gt;trend analysis, peaks/troughs,&lt;br&gt;predictions, economist perspective.&lt;br&gt;Bedrock with retry." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#78A8D8;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="360" width="240" height="180" as="geometry"/>
        </mxCell>

